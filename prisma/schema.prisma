generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id       String @id
  username String @unique
}

model School {
  id          String       @id @default(uuid())
  name        String       @unique
  students    Student[]
  teachers    Teacher[]
  attendances Attendance[]
  parents     Parent[]
}

model Student {
  id       String @id
  username String @unique
  clerkId  String @unique

  name      String
  surname   String
  email     String?  @unique
  phone     String?  @unique
  address   String
  img       String?
  bloodType String?
  sex       UserSex
  createdAt DateTime @default(now())
  parentId  String?
  classId   Int?
  levelId   Int // Changed from gradeId
  birthday  DateTime

  payments    Payment[]
  attendances Attendance[]
  results     Result[]
  class       Class?       @relation(fields: [classId], references: [id])
  level       Level        @relation(fields: [levelId], references: [id]) // Relation updated
  parent      Parent?      @relation(fields: [parentId], references: [id])
  schoolId    String?
  school      School?      @relation(fields: [schoolId], references: [id])
  promotions  Promotion[]

  @@index([name])
  @@index([username])
}

model Teacher {
  id          String       @id
  username    String       @unique
  clerkId     String       @unique
  schoolId    String? // 🎯 Make this optional with a "?"
  school      School?      @relation(fields: [schoolId], references: [id])
  name        String
  surname     String
  email       String?      @unique
  phone       String?      @unique
  address     String
  img         String?
  bloodType   String
  sex         UserSex
  createdAt   DateTime     @default(now())
  birthday    DateTime
  exams       Exam[]
  classes     Class[]
  subjects    Subject[]    @relation("SubjectToTeacher")
  assignments Assignment[]

  receivedMessages Message[] @relation("ReceivedMessages")

  @@index([name])
  @@index([username])
}

model Parent {
  id        String    @id
  clerkId   String    @unique
  username  String    @unique
  name      String
  surname   String
  email     String?   @unique
  phone     String    @unique
  address   String
  createdAt DateTime  @default(now())
  students  Student[]
  schoolId  String?
  school    School?   @relation(fields: [schoolId], references: [id])
}

model Level {
  id       Int    @id @default(autoincrement())
  level    Int    @unique
  name     String @unique
  schoolId String @default("school1")

  feeStructures FeeStructure[]
  classes       Class[]
  students      Student[]
}

model Class {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  capacity      Int
  supervisorId  String?
  levelId       Int
  schoolId      String         @default("school1")
  announcements Announcement[]
  level         Level          @relation(fields: [levelId], references: [id])
  supervisor    Teacher?       @relation(fields: [supervisorId], references: [id])
  events        Event[]
  students      Student[]
  subjects      Subject[]
  exams         Exam[]
  assignments   Assignment[]
}

model Subject {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  teachers    Teacher[]    @relation("SubjectToTeacher")
  classes     Class[]
  results     Result[]
  exams       Exam[]
  assignments Assignment[]
  attendances Attendance[]
  schoolId    String       @default("default_school")
}

model Exam {
  id        Int      @id @default(autoincrement())
  title     String
  startTime DateTime
  endTime   DateTime

  // 🎯 Direct links instead of 'lessonId'
  subjectId Int
  subject   Subject  @relation(fields: [subjectId], references: [id])
  classId   Int
  class     Class    @relation(fields: [classId], references: [id])
  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  results   Result[]
}

model Assignment {
  id        Int      @id @default(autoincrement())
  title     String
  startDate DateTime
  dueDate   DateTime
  results   Result[]

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])

  classId Int
  class   Class @relation(fields: [classId], references: [id])

  subjectId Int
  subject   Subject @relation(fields: [subjectId], references: [id])
}

model Result {
  id String @id @default(uuid())

  // 1. Declare the actual fields first! 🎯
  studentId      String
  subjectId      Int // Ensure this is Int if Subject ID is an Int
  academicYearId Int
  term           Int

  examId Int?
  exam   Exam? @relation(fields: [examId], references: [id])

  // 2. Then define the relations
  student      Student      @relation(fields: [studentId], references: [id])
  subject      Subject      @relation(fields: [subjectId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  assignmentScore Int?
  testScore       Int?
  examScore       Int?
  totalScore      Int?
  grade           String?
  remark          String?
  assignment      Assignment? @relation(fields: [assignmentId], references: [id])
  assignmentId    Int?
  testId          Int?

  // 3. Now the unique constraint will work because the fields exist above
  @@unique([studentId, subjectId, academicYearId, term])
}

model Attendance {
  id        Int      @id @default(autoincrement())
  date      DateTime
  present   Boolean
  studentId String

  student Student @relation(fields: [studentId], references: [id])

  subject   Subject @relation(fields: [subjectId], references: [id])
  subjectId Int

  school   School @relation(fields: [schoolId], references: [id])
  schoolId String

  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  academicYearId Int

  @@unique([date, studentId])
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  startTime   DateTime
  endTime     DateTime
  classId     Int?
  class       Class?   @relation(fields: [classId], references: [id])
}

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  date        DateTime
  classId     Int?
  class       Class?   @relation(fields: [classId], references: [id])
}

model Message {
  id         Int       @id @default(autoincrement())
  content    String
  createdAt  DateTime  @default(now())
  senderId   String
  receiverId String
  isRead     Boolean   @default(false)
  readAt     DateTime?
  receiver   Teacher   @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender     User      @relation("SentMessages", fields: [senderId], references: [id])
}

model User {
  id       String  @id
  username String  @unique
  role     String
  img      String?

  sentMessages Message[] @relation("SentMessages")
}

model Income {
  id     Int      @id @default(autoincrement())
  title  String
  amount Float
  date   DateTime @default(now())
}

model Expense {
  id     Int      @id @default(autoincrement())
  title  String
  amount Float
  date   DateTime @default(now())
}

model SchoolSettings {
  id           Int      @id @default(1)
  schoolName   String   @default("Rubix School")
  currentYear  String   @default("2025-2026")
  currentTerm  String   @default("Term 1")
  passingGrade Int      @default(50)
  updatedAt    DateTime @updatedAt
}

model AcademicYear {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  isCurrent     Boolean        @default(false)
  results       Result[]
  promotions    Promotion[]
  feeStructures FeeStructure[]
  payments      Payment[]
  attendances   Attendance[]
}

model Promotion {
  id             Int          @id @default(autoincrement())
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id])
  academicYearId Int
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  oldClassId     Int
  newClassId     Int
  status         String // "PROMOTED", "REPEATED", "GRADUATED"
  createdAt      DateTime     @default(now())
}

model FeeStructure {
  id             Int          @id @default(autoincrement())
  academicYearId Int
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  levelId        Int // Changed from gradeId
  level          Level        @relation(fields: [levelId], references: [id])
  amount         Decimal
  description    String?
}

model Payment {
  id             Int          @id @default(autoincrement())
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id])
  amountPaid     Decimal
  date           DateTime     @default(now())
  method         String
  academicYearId Int
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
}

enum UserSex {
  MALE
  FEMALE
}

enum Day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
}
