generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id       String @id
  username String @unique
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])
}

model School {
  id          String       @id @default(uuid())
  name        String       @unique
  admins      Admin[]
  admissions  Admission[]
  attendances Attendance[]
  parents     Parent[]
  students    Student[]
  teachers    Teacher[]
}

model Student {
  id          String           @id
  username    String           @unique
  clerkId     String           @unique
  name        String
  surname     String
  email       String?          @unique
  phone       String?          @unique
  address     String
  img         String?
  bloodType   String?
  sex         UserSex
  createdAt   DateTime         @default(now())
  parentId    String?
  classId     Int?
  levelId     Int
  birthday    DateTime
  schoolId    String?
  attendances Attendance[]
  notificationLogs NotificationLog[]
  payments    Payment[]
  promotions  Promotion[]
  balances    StudentBalance[]
  results     Result[]
  class       Class?           @relation(fields: [classId], references: [id])
  level       Level            @relation(fields: [levelId], references: [id])
  parent      Parent?          @relation(fields: [parentId], references: [id])
  school      School?          @relation(fields: [schoolId], references: [id])

  @@index([name])
  @@index([username])
}

model Admission {
  id                String          @id @default(cuid())
  applicationNumber String          @unique
  firstName         String
  lastName          String
  middleName        String?
  gender            UserSex
  dateOfBirth       DateTime
  passportPhoto     String?
  email             String?
  phone             String
  address           String
  state             String
  lga               String
  parentName        String
  parentPhone       String
  parentEmail       String?
  parentOccupation  String?
  previousSchool    String?
  lastClass         String?
  applyingLevelId   Int
  applyingClassId   Int?
  bloodGroup        String?
  genotype          String?
  medicalCondition  String?
  birthCertificate  String?
  reportCard        String?
  transferLetter    String?
  admissionNumber   String?         @unique
  status            AdmissionStatus @default(PENDING)
  remarks           String?
  submittedAt       DateTime        @default(now())
  reviewedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  schoolId          String
  applyingClass     Class?          @relation(fields: [applyingClassId], references: [id])
  applyingLevel     Level           @relation(fields: [applyingLevelId], references: [id])
  school            School          @relation(fields: [schoolId], references: [id])

  @@index([status])
  @@index([schoolId])
  @@index([applyingLevelId])
  @@index([applyingClassId])
}

model Lesson {
  id        Int      @id @default(autoincrement())
  name      String
  day       Day
  startTime DateTime
  endTime   DateTime
  subjectId Int
  classId   Int
  teacherId String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model Teacher {
  id               String       @id
  username         String       @unique
  clerkId          String       @unique
  schoolId         String?
  name             String
  surname          String
  email            String?      @unique
  phone            String?      @unique
  address          String
  img              String?
  bloodType        String
  sex              UserSex
  createdAt        DateTime     @default(now())
  birthday         DateTime
  assignments      Assignment[]
  classes          Class[]
  exams            Exam[]
  lessons          Lesson[]
  receivedMessages Message[]    @relation("ReceivedMessages")
  school           School?      @relation(fields: [schoolId], references: [id])
  subjects         Subject[]    @relation("SubjectToTeacher")

  @@index([name])
  @@index([username])
}

model Parent {
  id        String    @id
  clerkId   String    @unique
  username  String    @unique
  name      String
  surname   String
  email     String?   @unique
  phone     String    @unique
  address   String
  createdAt DateTime  @default(now())
  schoolId  String?
  school    School?   @relation(fields: [schoolId], references: [id])
  students  Student[]
}

model Level {
  id            Int            @id @default(autoincrement())
  level         Int            @unique
  name          String         @unique
  schoolId      String         @default("school1")
  admissions    Admission[]
  classes       Class[]
  feeStructures FeeStructure[]
  students      Student[]
}

model Class {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  capacity      Int
  supervisorId  String?
  levelId       Int
  schoolId      String         @default("school1")
  admissions    Admission[]
  announcements Announcement[]
  assignments   Assignment[]
  level         Level          @relation(fields: [levelId], references: [id])
  supervisor    Teacher?       @relation(fields: [supervisorId], references: [id])
  events        Event[]
  exams         Exam[]
  lessons       Lesson[]
  students      Student[]
  subjects      Subject[]      @relation("ClassToSubject")
}

model Subject {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  schoolId    String       @default("default_school")
  assignments Assignment[]
  attendances Attendance[]
  exams       Exam[]
  lessons     Lesson[]
  results     Result[]
  classes     Class[]      @relation("ClassToSubject")
  teachers    Teacher[]    @relation("SubjectToTeacher")
}

model Exam {
  id        Int      @id @default(autoincrement())
  title     String
  startTime DateTime
  endTime   DateTime
  subjectId Int
  classId   Int
  teacherId String
  class     Class    @relation(fields: [classId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id])
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  results   Result[]
}

model Assignment {
  id        Int      @id @default(autoincrement())
  title     String
  startDate DateTime
  dueDate   DateTime
  teacherId String
  classId   Int
  subjectId Int
  class     Class    @relation(fields: [classId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id])
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  results   Result[]
}

model Result {
  id              String       @id @default(uuid())
  studentId       String
  subjectId       Int
  academicYearId  Int
  term            Int
  examId          Int?
  assignmentScore Int?
  testScore       Int?
  examScore       Int?
  totalScore      Int?
  grade           String?
  remark          String?
  assignmentId    Int?
  testId          Int?
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id])
  assignment      Assignment?  @relation(fields: [assignmentId], references: [id])
  exam            Exam?        @relation(fields: [examId], references: [id])
  student         Student      @relation(fields: [studentId], references: [id])
  subject         Subject      @relation(fields: [subjectId], references: [id])

  @@unique([studentId, subjectId, academicYearId, term])
}

model Attendance {
  id             Int          @id @default(autoincrement())
  date           DateTime
  present        Boolean
  studentId      String
  subjectId      Int?
  teacherId      String?
  schoolId       String
  academicYearId Int
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  school         School       @relation(fields: [schoolId], references: [id])
  student        Student      @relation(fields: [studentId], references: [id])
  subject        Subject?     @relation(fields: [subjectId], references: [id])

  @@unique([date, studentId])
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  startTime   DateTime
  endTime     DateTime
  classId     Int?
  class       Class?   @relation(fields: [classId], references: [id])
}

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  date        DateTime
  classId     Int?
  class       Class?   @relation(fields: [classId], references: [id])
}

model Message {
  id         Int       @id @default(autoincrement())
  content    String
  createdAt  DateTime  @default(now())
  senderId   String
  receiverId String
  isRead     Boolean   @default(false)
  readAt     DateTime?
  receiver   Teacher   @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender     User      @relation("SentMessages", fields: [senderId], references: [id])
}

model User {
  id           String    @id
  username     String    @unique
  role         String
  img          String?
  sentMessages Message[] @relation("SentMessages")
}

model Income {
  id     Int      @id @default(autoincrement())
  title  String
  amount Float
  date   DateTime @default(now())
}

model Expense {
  id     Int      @id @default(autoincrement())
  title  String
  amount Float
  date   DateTime @default(now())
}

model SchoolSettings {
  id           Int      @id @default(1)
  schoolName   String   @default("Rubix School")
  currentYear  String   @default("2025-2026")
  currentTerm  String   @default("Term 1")
  passingGrade Int      @default(50)
  updatedAt    DateTime @updatedAt
}

model AcademicYear {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  isCurrent     Boolean        @default(false)
  attendances   Attendance[]
  feeStructures FeeStructure[]
  payments      Payment[]
  promotions    Promotion[]
  results       Result[]
}

model Promotion {
  id             Int          @id @default(autoincrement())
  studentId      String
  academicYearId Int
  oldClassId     Int
  newClassId     Int
  status         String
  createdAt      DateTime     @default(now())
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  student        Student      @relation(fields: [studentId], references: [id])
}

model FeeStructure {
  id             Int          @id @default(autoincrement())
  academicYearId Int
  levelId        Int
  amount         Decimal
  description    String?
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  level          Level        @relation(fields: [levelId], references: [id])
}

model Payment {
  id             Int          @id @default(autoincrement())
  studentId      String
  amountPaid     Decimal
  date           DateTime     @default(now())
  method         String
  academicYearId Int
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  student        Student      @relation(fields: [studentId], references: [id])
}

model FeeCategory {
  id             Int             @id @default(autoincrement())
  name           String
  description    String?
  feeAllocations FeeAllocation[]
  createdAt      DateTime        @default(now())
}

model FeeAllocation {
  id            Int         @id @default(autoincrement())
  feeCategoryId Int
  category      FeeCategory @relation(fields: [feeCategoryId], references: [id], onDelete: Cascade)
  levelId       Int
  amount        Decimal     @db.Decimal(10, 2)
  term          String
  academicYear  String
  createdAt     DateTime    @default(now())

  studentBalances StudentBalance[]
  paymentRecords  PaymentRecord[]
}

model StudentBalance {
  id               Int           @id @default(autoincrement())
  studentId        String?
  student          Student?       @relation(fields: [studentId], references: [id])
  feeAllocationId  Int
  allocation       FeeAllocation @relation(fields: [feeAllocationId], references: [id], onDelete: Cascade)
  totalAssigned    Decimal       @db.Decimal(10, 2)
  paidAmount       Decimal       @default(0.00) @db.Decimal(10, 2)
  outstanding      Decimal       @db.Decimal(10, 2)
  status           PaymentStatus @default(UNPAID)
  lastReminderSent DateTime?
  updatedAt        DateTime      @updatedAt

  paymentRecords PaymentRecord[]

  @@unique([studentId, feeAllocationId])
}

model PaymentRecord {
  id               Int            @id @default(autoincrement())
  studentBalanceId Int
  balance          StudentBalance @relation(fields: [studentBalanceId], references: [id], onDelete: Cascade)
  feeAllocationId  Int
  allocation       FeeAllocation  @relation(fields: [feeAllocationId], references: [id])
  amountPaid       Decimal        @db.Decimal(10, 2)
  paymentMethod    PaymentMethod
  reference        String         @unique
  status           String
  channel          String?
  paidAt           DateTime       @default(now())
}

model NotificationLog {
  id        String   @id @default(uuid())
  type      String   // "ATTENDANCE" | "FEE_REMINDER" | "RESULT"
  recipient String   // Phone number or Email
  status    String   // "SUCCESS" | "FAILED"
  message   String
  createdAt DateTime @default(now())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  FULLY_PAID
}

enum PaymentMethod {
  PAYSTACK
  CASH
  BANK_TRANSFER
}

enum AdmissionStatus {
  PENDING
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  ENROLLED
}

enum UserSex {
  MALE
  FEMALE
}

enum Day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
}
